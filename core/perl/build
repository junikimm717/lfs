#!/bin/sh

set -eu

DIR="$(realpath "$(dirname "$0" )" )"
cd "$DIR"

# You MUST make sure that we are in a correct environment.
test -z "$INOSENV" && {
  echo "You cannot run this script while not in the mimuxenv!" && \
  exit 1;
}

VERSION="5.42.2"
BASEURL=https://www.cpan.org/src/5.0
SRCDIR="perl-$VERSION"
TARBALL="$SRCDIR.tar.xz"

# mimux builds perl "natively": BUILDTRIPLE == TARGET (same arch, musl), so the
# miniperl produced during the build runs directly on the build host and perl's
# own Configure/make/make-depend flow works unmodified. We only force the musl
# headers (-nostdinc + the -I paths already in CFLAGS) so nothing leaks in from
# a host libc.
export CPP="$CPP -nostdinc"
export CFLAGS="$CFLAGS -nostdinc"

download() {
  cd "$DIR"
  echo "downloading perl source..."
  if test -f "$TARBALL"; then
    echo "$TARBALL exists, skipping..."
  else
    curl -LOf $BASEURL/$TARBALL
  fi
}

extract() {
  cd "$DIR"
  echo "extracting perl source..."
  if ! test -f "$TARBALL"; then
    echo "No tarball to operate on!"
    exit 1
  fi

  tar xf "$TARBALL"
  chmod -R u+w "$SRCDIR"
  cd "$SRCDIR"
  # -Dfirstmakefile=GNUmakefile: perl's `make depend` step does
  # `cp Makefile $firstmakefile` (defaulting to `makefile`). On the
  # case-insensitive macOS APFS volume that Orbstack exposes through the
  # bind mount, `Makefile` and `makefile` are the same path, so cp aborts
  # with "input and output are the same file". GNUmakefile is also
  # preferred by GNU make ahead of Makefile, so subsequent `make` calls
  # still pick up the dependency-enriched copy.
  ./Configure -des -Dprefix=/usr \
    -Dcflags="$CFLAGS $LDFLAGS" \
    -Dprefix=/usr \
    -Dvendorprefix=/usr \
    -Dman1dir=/usr/share/man/man1 \
    -Dman3dir=/usr/share/man/man3 \
    -Dsitelib=/usr/lib/perl5/site_perl \
    -Dvendorlib=/usr/lib/perl5/vendor_perl \
    -Dprivlib=/usr/lib/perl5/core_perl \
    -Darchlib=/usr/lib/perl5/core_perl \
    -Dsitearch=/usr/lib/perl5/site_perl \
    -Dvendorarch=/usr/lib/perl5/vendor_perl \
    -Dlocincpth=" " -Dloclibpth=" " \
    -Dcf_by="mimux" \
    -Dusedevel \
    -Dfirstmakefile=GNUmakefile \
    -Dvendorprefix=/usr

  # musl compatibility: perl's eaccess()/uselocale() probes misfire against
  # musl, so pin them off explicitly. usrinc is blanked because we feed headers
  # through -I (see -nostdinc above) rather than a single /usr/include.
  echo 'd_eaccess=undef' >> ./config.sh
  echo 'usrinc=' >> ./config.sh
  echo "d_uselocale='undef'" >> config.sh
  echo '#undef HAS_EACCESS' >> ./config.h

  # We appended to config.sh after Configure generated the Makefile, so make
  # would otherwise try to regenerate the Makefile from Makefile.SH mid-build.
  # Equalize timestamps so it doesn't.
  find . -type f -exec touch {} +
}

makeinstall() {
  echo "building perl..."

  if ! test -d "$DIR/$SRCDIR"; then
    echo "No source directory to operate on!"
    exit 1
  fi
  cd "$DIR/$SRCDIR"

  # The lowercase 'makefile' (Makefile + filled-in header dependencies) is
  # generated by perl's own 'make depend'. Run it first so the parallel build
  # never races on bootstrapping it.
  echo "==========================make depend==========================="
  make depend
  echo "==========================make running==========================="
  make -j"${JOBS:-8}"
  echo "==========================make install==========================="
  make -j"${JOBS:-8}" DESTDIR="$ROOTFS" install

  # perl's installperl populates the arch-dependent modules (Config, Errno, the
  # XS .pm/.so) into privlib but NOT the architecture-independent pure-perl core
  # modules (strict.pm, warnings.pm, Exporter.pm, ...). Stage them from the
  # built ./lib ourselves; --exclude drops the bundled test files.
  rsync -a --no-o --no-g --exclude='*.t' ./lib/ "$ROOTFS/usr/lib/perl5/core_perl/"

  # -Dusedevel installs only version-suffixed binaries; provide the bare names.
  for file in perl perlbug perldoc perlivp perlthanks cpan shasum; do
    ln -sfn "$file$VERSION" "$ROOTFS/usr/bin/$file"
  done
}

clear() {
  cd "$DIR"
  rm -rf ./*.tgz ./*.tar.xz ./*.tar.bz2 ./*.tar.gz "$SRCDIR" "$TARBALL"
}

cd "$DIR"
case "$1" in
  download|d)
    download
    ;;
  extract|e)
    extract
    ;;
  makeinstall|mi)
    makeinstall
    ;;
  clear|clean|c)
    clear
    ;;
  all|a)
    download && extract && makeinstall
    ;;
  *)
    cat <<EOF
Build script for perl

download|d -> download the tarball
extract|e -> extract and patch the tarball
makeinstall|mi -> make and install the build artifacts
clear|clean|c -> clean all artifacts
all|a -> clean, and then go through everything.
EOF
    exit 1
    ;;
esac
